# ─── Informeer Environment Variables ───
# Copy to .env and fill in required values.

# Server
PORT=3011
HOST=0.0.0.0

# Database
DATABASE_PATH=./data/informeer.db
DATA_DIR=./data

# Security — REQUIRED in production
# Generate with: openssl rand -hex 32
SECRET_KEY=

# Admin credentials (used to seed initial user on first start)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
