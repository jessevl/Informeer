# ─── Server ───
PORT=3011
HOST=0.0.0.0

# ─── Database ───
DATABASE_PATH=./data/informeer.db
DATA_DIR=./data

# ─── Security ───
# REQUIRED in production — used to encrypt secrets at rest (AES-256-GCM)
# Generate with: openssl rand -hex 32
SECRET_KEY=

# ─── Admin credentials (used to seed the initial user on first start) ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
